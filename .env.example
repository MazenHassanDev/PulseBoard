# Backend (Django) environment variables.
# Copy to .env for local development. In production these are set on Render.

# Django
SECRET_KEY=replace-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Anthropic API key for the AI explainer
ANTHROPIC_API_KEY=sk-ant-...

# Database — local development uses the discrete DB_* vars below.
# In production, Render injects a single DATABASE_URL instead (takes precedence).
DB_NAME=campaigns_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis (dashboard + AI explainer caching)
REDIS_URL=redis://127.0.0.1:6379

# Production-only (set on Render). Comma-separated, each value includes the scheme.
# CORS_ALLOWED_ORIGINS=https://pulseboard-web.onrender.com
# CSRF_TRUSTED_ORIGINS=https://pulseboard-api.onrender.com
